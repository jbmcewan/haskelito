{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/adt", "src/collections", "src/combinators", "src/monads", "src/monoids"],
  "entryPointStrategy": "expand",
  "tsconfig": "tsconfig.build.json",
  "out": "docs/api",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "excludeReferences": true,
  "intentionallyNotExported": ["ReaderModule", "EffectValue"],
  "sort": ["source-order"],
  "readme": "none",
  "name": "haskelito API"
}
