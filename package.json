{
  "name": "haskelito",
  "version": "0.1.0",
  "description": "Small functional programming utilities for JavaScript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbmcewan/haskelito.git"
  },
  "homepage": "https://github.com/jbmcewan/haskelito#readme",
  "bugs": {
    "url": "https://github.com/jbmcewan/haskelito/issues"
  },
  "keywords": [
    "functional",
    "fp",
    "maybe",
    "either",
    "validation",
    "reader",
    "monad",
    "monoid"
  ],
  "author": "J.B.McEwan",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adt/*": {
      "import": "./dist/adt/*.js",
      "require": "./dist/adt/*.cjs"
    },
    "./collections/*": {
      "import": "./dist/collections/*.js",
      "require": "./dist/collections/*.cjs"
    },
    "./combinators/*": {
      "import": "./dist/combinators/*.js",
      "require": "./dist/combinators/*.cjs"
    },
    "./monads/*": {
      "import": "./dist/monads/*.js",
      "require": "./dist/monads/*.cjs"
    },
    "./monoids/*": {
      "import": "./dist/monoids/*.js",
      "require": "./dist/monoids/*.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-fp": "^2.3.0",
    "eslint-plugin-functional": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.0",
    "vite": "^8.1.0",
    "vitest": "^3.2.4"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
