{
  "name": "@jbmcewan/haskelito",
  "version": "2.0.1",
  "description": "Small functional programming utilities for JavaScript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "engines": {
    "node": ">=22.22.1",
    "npm": ">=11.18.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jbmcewan/haskelito.git"
  },
  "homepage": "https://github.com/jbmcewan/haskelito#readme",
  "bugs": {
    "url": "https://github.com/jbmcewan/haskelito/issues"
  },
  "keywords": [
    "functional",
    "fp",
    "maybe",
    "either",
    "validation",
    "reader",
    "monad",
    "monoid"
  ],
  "author": "J.B.McEwan",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adt/*": {
      "types": "./dist/adt/*.d.ts",
      "import": "./dist/adt/*.js",
      "require": "./dist/adt/*.cjs"
    },
    "./collections/*": {
      "types": "./dist/collections/*.d.ts",
      "import": "./dist/collections/*.js",
      "require": "./dist/collections/*.cjs"
    },
    "./combinators/*": {
      "types": "./dist/combinators/*.d.ts",
      "import": "./dist/combinators/*.js",
      "require": "./dist/combinators/*.cjs"
    },
    "./monads/*": {
      "types": "./dist/monads/*.d.ts",
      "import": "./dist/monads/*.js",
      "require": "./dist/monads/*.cjs"
    },
    "./monoids/*": {
      "types": "./dist/monoids/*.d.ts",
      "import": "./dist/monoids/*.js",
      "require": "./dist/monoids/*.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && npm run build:types && npm run build:docs",
    "build:package": "vite build && npm run build:types",
    "build:docs": "typedoc --options typedoc.json",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "npm run build:package",
    "setup:git-hooks": "node ./scripts/install-husky.js"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,ts,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-functional": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.0",
    "typedoc": "^0.28.12",
    "typescript-eslint": "^8.38.0",
    "typescript": "^5.9.2",
    "vite": "^8.1.0",
    "vitest": "^3.2.4"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
